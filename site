<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Приветствие</title>
    <style>
        /* Стили для всего фона страницы */
        body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            /* Мягкий сине-серый градиент на фоне */
            background: linear-gradient(135deg, #e0eafc 0%, #cfdef3 100%);
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }

        /* Белый контейнер-карточка по центру */
        .card {
            background-color: #ffffff;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            text-align: center;
            max-width: 500px;
            width: 90%;
            transition: transform 0.3s ease;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        /* Стили для заголовка (синий цвет) */
        h1 {
            color: #1e3a8a; /* Глубокий красивый синий цвет */
            margin-top: 0;
            margin-bottom: 25px;
            font-size: 2.5rem;
            letter-spacing: 1px;
        }

        /* Стили для картинки */
        .image-wrapper img {
            width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
            display: block;
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>Привет, Алексей!</h1>
        
        <div class="image-wrapper">
            <img src="https://images.unsplash.com/photo-1506744626753-1fa30f377215?auto=format&fit=crop&w=600&q=80" alt="Красивый пейзаж">
        </div>
    </div>

</body>
</html>
